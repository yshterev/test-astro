---
import astroLogo from "../assets/astro.svg";
---

<header class="navbar bg-base-100/80 sticky top-0 z-10 backdrop-blur">
  <div class="navbar-start">
    <a href="https://astro.build" class="btn btn-ghost gap-2">
      <img
        src={astroLogo.src}
        width="32"
        height="32"
        alt="Astro"
        class="h-8 w-auto"
      />
      <span class="font-bold normal-case text-lg">Astro Starter</span>
    </a>
  </div>
  <div class="navbar-end hidden md:flex gap-2">
    <a
      href="https://docs.astro.build"
      id="test-btn"
      class="btn btn-ghost btn-sm">Docs</a
    >
    <a href="https://astro.build/chat" class="btn btn-ghost btn-sm">Discord</a>
  </div>
</header>

<script>
  const menu = document.querySelector("#test-btn");

  menu?.addEventListener("click", (e) => {
    e.preventDefault();
    e.stopPropagation();
    console.log("");
    // const isExpanded = menu.getAttribute('aria-expanded') === 'true';
    // menu.setAttribute('aria-expanded', `${!isExpanded}`);
  });
</script>
